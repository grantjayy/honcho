# Honcho self-hosted configuration for Hermes Agent.
# Secrets live in .env; this file is safe to inspect.

[app]
LOG_LEVEL = "INFO"
SESSION_OBSERVERS_LIMIT = 10
GET_CONTEXT_MAX_TOKENS = 100000
MAX_FILE_SIZE = 5242880
MAX_MESSAGE_SIZE = 25000
EMBED_MESSAGES = true
NAMESPACE = "honcho"

[db]
CONNECTION_URI = "postgresql+psycopg://postgres:postgres@database:5432/postgres"
SCHEMA = "public"
POOL_CLASS = "default"
POOL_PRE_PING = true
POOL_SIZE = 10
MAX_OVERFLOW = 20
POOL_TIMEOUT = 30
POOL_RECYCLE = 300
POOL_USE_LIFO = true
SQL_DEBUG = false
TRACING = false

[auth]
USE_AUTH = false
JWT_SECRET = "local-dev-not-used-auth-disabled"

[sentry]
ENABLED = false
DSN = ""
RELEASE = ""
ENVIRONMENT = "local"
TRACES_SAMPLE_RATE = 0.0
PROFILES_SAMPLE_RATE = 0.0

[llm]
MAX_TOOL_OUTPUT_CHARS = 20000
MAX_MESSAGE_CONTENT_CHARS = 5000

[embedding]
VECTOR_DIMENSIONS = 1536
MAX_INPUT_TOKENS = 8192
MAX_TOKENS_PER_REQUEST = 300000

[embedding.model_config]
transport = "openai"
model = "openai/text-embedding-3-large"
dimensions_mode = "always"

[embedding.model_config.overrides]
base_url = "https://openrouter.ai/api/v1"
api_key_env = "LLM_OPENAI_API_KEY"

[deriver]
ENABLED = true
WORKERS = 1
POLLING_SLEEP_INTERVAL_SECONDS = 1.0
STALE_SESSION_TIMEOUT_MINUTES = 5
DEDUPLICATE = true
LOG_OBSERVATIONS = false
MAX_INPUT_TOKENS = 25000
MAX_CUSTOM_INSTRUCTIONS_TOKENS = 2000
WORKING_REPRESENTATION_MAX_OBSERVATIONS = 100
REPRESENTATION_BATCH_MAX_TOKENS = 1024
FLUSH_ENABLED = true

[deriver.model_config]
transport = "openai"
model = "x-ai/grok-4.3"
thinking_effort = "medium"

[deriver.model_config.overrides]
base_url = "https://openrouter.ai/api/v1"
api_key_env = "LLM_OPENAI_API_KEY"

[peer_card]
ENABLED = true

[dialectic]
MAX_INPUT_TOKENS = 100000
HISTORY_TOKEN_LIMIT = 8192
SESSION_HISTORY_MAX_TOKENS = 4096

[dialectic.levels.minimal]
MAX_TOOL_ITERATIONS = 3
TOOL_CHOICE = "auto"

[dialectic.levels.minimal.model_config]
transport = "openai"
model = "deepseek/deepseek-v4-flash"

[dialectic.levels.minimal.model_config.overrides]
base_url = "https://openrouter.ai/api/v1"
api_key_env = "LLM_OPENAI_API_KEY"

[dialectic.levels.minimal.model_config.overrides.provider_params.provider]
order = ["fireworks"]
allow_fallbacks = true

[dialectic.levels.low]
MAX_TOOL_ITERATIONS = 5
TOOL_CHOICE = "auto"

[dialectic.levels.low.model_config]
transport = "openai"
model = "deepseek/deepseek-v4-flash"

[dialectic.levels.low.model_config.overrides]
base_url = "https://openrouter.ai/api/v1"
api_key_env = "LLM_OPENAI_API_KEY"

[dialectic.levels.low.model_config.overrides.provider_params.provider]
order = ["fireworks"]
allow_fallbacks = true

[dialectic.levels.medium]
MAX_TOOL_ITERATIONS = 2

[dialectic.levels.medium.model_config]
transport = "openai"
model = "x-ai/grok-4.3"
thinking_effort = "medium"

[dialectic.levels.medium.model_config.overrides]
base_url = "https://openrouter.ai/api/v1"
api_key_env = "LLM_OPENAI_API_KEY"

[dialectic.levels.high]
MAX_TOOL_ITERATIONS = 4

[dialectic.levels.high.model_config]
transport = "openai"
model = "openai/gpt-5.5"
thinking_effort = "medium"

[dialectic.levels.high.model_config.overrides]
base_url = "https://openrouter.ai/api/v1"
api_key_env = "LLM_OPENAI_API_KEY"

[dialectic.levels.max]
MAX_TOOL_ITERATIONS = 10

[dialectic.levels.max.model_config]
transport = "openai"
model = "openai/gpt-5.5"
thinking_effort = "high"

[dialectic.levels.max.model_config.overrides]
base_url = "https://openrouter.ai/api/v1"
api_key_env = "LLM_OPENAI_API_KEY"

[summary]
ENABLED = true
MESSAGES_PER_SHORT_SUMMARY = 20
MESSAGES_PER_LONG_SUMMARY = 60

[summary.model_config]
transport = "openai"
model = "x-ai/grok-4.3"
thinking_effort = "medium"

[summary.model_config.overrides]
base_url = "https://openrouter.ai/api/v1"
api_key_env = "LLM_OPENAI_API_KEY"

[dream]
ENABLED = true
DOCUMENT_THRESHOLD = 50
IDLE_TIMEOUT_MINUTES = 60
MIN_HOURS_BETWEEN_DREAMS = 4
ENABLED_TYPES = ["omni"]
MAX_TOOL_ITERATIONS = 20
HISTORY_TOKEN_LIMIT = 16384

[dream.deduction_model_config]
transport = "openai"
model = "openai/gpt-5.5"
thinking_effort = "high"

[dream.deduction_model_config.overrides]
base_url = "https://openrouter.ai/api/v1"
api_key_env = "LLM_OPENAI_API_KEY"

[dream.induction_model_config]
transport = "openai"
model = "openai/gpt-5.5"
thinking_effort = "high"

[dream.induction_model_config.overrides]
base_url = "https://openrouter.ai/api/v1"
api_key_env = "LLM_OPENAI_API_KEY"

[dream.surprisal]
ENABLED = false
TREE_TYPE = "kdtree"
TREE_K = 5
SAMPLING_STRATEGY = "recent"
SAMPLE_SIZE = 200
TOP_PERCENT_SURPRISAL = 0.10
MIN_HIGH_SURPRISAL_FOR_REPLACE = 10
INCLUDE_LEVELS = ["explicit", "deductive"]

[webhook]
SECRET = ""
MAX_WORKSPACE_LIMIT = 10

[metrics]
ENABLED = false

[telemetry]
ENABLED = false
BATCH_SIZE = 100
FLUSH_INTERVAL_SECONDS = 1.0
FLUSH_THRESHOLD = 50
MAX_RETRIES = 3
MAX_BUFFER_SIZE = 10000

[cache]
ENABLED = true
URL = "redis://redis:6379/0?suppress=true"
DEFAULT_TTL_SECONDS = 300
DEFAULT_LOCK_TTL_SECONDS = 5

[vector_store]
TYPE = "pgvector"
MIGRATED = false
NAMESPACE = "honcho"
